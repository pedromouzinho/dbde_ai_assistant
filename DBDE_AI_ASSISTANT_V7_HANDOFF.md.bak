# Integrações externas (opcionais)
FIGMA_ACCESS_TOKEN        = (Figma Personal Access Token — read permissions)
MIRO_ACCESS_TOKEN         = (Miro OAuth token — boards:read)

# Opcional (quando Anthropic estiver disponível):
