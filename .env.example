# =============================================================================
# .env.example — Template for local development environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# =============================================================================
# AUTH (REQUIRED in production)
# =============================================================================
# SECURITY: Replace ALL placeholder values before deployment.
# Generate JWT_SECRET with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_48_CHARS
JWT_EXPIRATION_HOURS=10
ADMIN_USERNAME=admin
ADMIN_DISPLAY_NAME=Admin User
# Generate a strong password: min 16 chars, mixed case + digits + symbols
ADMIN_INITIAL_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
AUTH_COOKIE_SECURE=true
APP_ENV=dev

# =============================================================================
# AZURE OPENAI (REQUIRED)
# =============================================================================
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
AZURE_OPENAI_KEY=
CHAT_DEPLOYMENT=gpt-4
EMBEDDING_DEPLOYMENT=text-embedding-3-small
API_VERSION_CHAT=2024-10-21
API_VERSION_OPENAI=2023-05-15

# =============================================================================
# LLM PROVIDER TIERS
# Format: "provider:deployment_name"
# Providers: azure_openai, anthropic
# =============================================================================
LLM_DEFAULT_TIER=standard
LLM_TIER_FAST=azure_openai:gpt-4-1-dz
LLM_TIER_STANDARD=azure_openai:gpt-4-1-dz
LLM_TIER_PRO=anthropic:opus
LLM_TIER_VISION=azure_openai:gpt-4-1-dz
LLM_FALLBACK=azure_openai:gpt-4-1-mini-dz

# =============================================================================
# ANTHROPIC (optional — for Claude models via Anthropic API or Azure Foundry)
# =============================================================================
ANTHROPIC_API_KEY=
# ANTHROPIC_FOUNDRY_RESOURCE=my-foundry-resource  # Azure AI Foundry resource name

# =============================================================================
# AZURE AI SEARCH (REQUIRED)
# =============================================================================
SEARCH_SERVICE=<search-service-name>
SEARCH_KEY=
API_VERSION_SEARCH=2023-11-01
DEVOPS_INDEX=millennium-devops-index
OMNI_INDEX=millennium-omni-index
EXAMPLES_INDEX=millennium-examples-index

# =============================================================================
# AZURE TABLE / BLOB STORAGE (REQUIRED)
# =============================================================================
STORAGE_ACCOUNT=<storage-account-name>
STORAGE_KEY=
STORAGE_CONNECTION_STRING=
UPLOAD_BLOB_CONTAINER_RAW=upload-raw
UPLOAD_BLOB_CONTAINER_TEXT=upload-text
UPLOAD_BLOB_CONTAINER_CHUNKS=upload-chunks
CHAT_TOOLRESULT_BLOB_CONTAINER=chat-tool-results
GENERATED_FILES_BLOB_CONTAINER=generated-files

# =============================================================================
# AZURE DEVOPS (REQUIRED for DevOps tools)
# =============================================================================
DEVOPS_PAT=
DEVOPS_ORG=ptbcp
DEVOPS_PROJECT=IT.DIT

# =============================================================================
# AZURE AI CONTENT SAFETY — Prompt Shield (optional but recommended)
# =============================================================================
CONTENT_SAFETY_ENDPOINT=https://<resource>.cognitiveservices.azure.com
CONTENT_SAFETY_KEY=
PROMPT_SHIELD_ENABLED=true

# =============================================================================
# AZURE AI LANGUAGE — PII Shield (optional but recommended)
# =============================================================================
PII_ENDPOINT=https://<resource>.cognitiveservices.azure.com
PII_API_KEY=
PII_ENABLED=true

# =============================================================================
# AZURE DOCUMENT INTELLIGENCE (optional)
# =============================================================================
DOC_INTEL_ENDPOINT=https://<resource>.cognitiveservices.azure.com
DOC_INTEL_KEY=
DOC_INTEL_ENABLED=true
DOC_INTEL_MODEL=prebuilt-layout

# =============================================================================
# FIGMA / MIRO (optional)
# =============================================================================
FIGMA_ACCESS_TOKEN=
MIRO_ACCESS_TOKEN=

# =============================================================================
# WEB SEARCH — Brave Search API (optional)
# =============================================================================
WEB_SEARCH_ENABLED=false
WEB_SEARCH_API_KEY=
WEB_ANSWERS_ENABLED=false
WEB_ANSWERS_API_KEY=

# =============================================================================
# POST-RETRIEVAL RERANK — Azure AI Foundry / Cohere (optional)
# =============================================================================
RERANK_ENABLED=true
RERANK_ENDPOINT=
RERANK_API_KEY=

# =============================================================================
# AGENT CONFIGURATION
# =============================================================================
AGENT_MAX_ITERATIONS=7
AGENT_MAX_TOKENS=8000
AGENT_TEMPERATURE=0.3

# =============================================================================
# CODE INTERPRETER
# =============================================================================
CODE_INTERPRETER_ENABLED=true
CODE_INTERPRETER_TIMEOUT=240

# =============================================================================
# UPLOAD / EXPORT
# =============================================================================
UPLOAD_MAX_FILE_MB=10
EXPORT_AUTO_ASYNC_ENABLED=true

# =============================================================================
# DEBUG
# =============================================================================
DEBUG_MODE=false
LOG_FORMAT=text
